          <label for="sf-name">First &amp; last name</label>
          <input type="text" id="sf-name" name="name" required placeholder="Your full name">
        </div>
        <div class="sejour-form-field">
          <label for="sf-email">Email</label>
          <input type="email" id="sf-email" name="email" required placeholder="you@example.com">
